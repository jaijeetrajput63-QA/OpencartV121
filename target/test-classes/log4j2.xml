<?xml version="1.0" encoding="UTF-8"?>


<Configuration status="INFO">

<Properties>
        <Property name="basePath">logs</Property>
</Properties>

    <Appenders>
        <!-- Console Appender -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} [%t] %-5level %logger{36} - %msg%n"/>
        </Console>

        <RollingFile name="File" fileName="${basePath}/automation.log" filePattern="${basePath}/automation-%d{yyyy-MM-dd}-%i.log.gz">
        <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} [%t] %-5level %logger{36} - %msg%n"/>
        <Policies>
        
        <!-- Rolls after 5MB -->
        <SizeBasedTriggeringPolicy size="5MB"/>
        <!-- Daily rolling -->
        <TimeBasedTriggeringPolicy interval="1" modulate="true"/>

        </Policies>
        
        <SizeBasedTriggeringPolicy size="5000" />	
        </RollingFile>

    </Appenders>

    <Loggers>
         <Root level="info"><!-- Here you can use multiple log levels All < Trace < Debug < Info < Warning < Error < Fatal < Off -->
           <!-- <AppenderRef ref="Console"/> -->
           <AppenderRef ref="File"/>
        </Root>
    </Loggers>

</Configuration>